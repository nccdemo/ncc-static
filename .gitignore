# =============================================================================
# ncc monorepo — single root .gitignore (backend + all frontend apps)
# =============================================================================

# --- Python ---
venv/
.venv/
env/
ENV/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.eggs/
*.egg

# --- Node (all subprojects) ---
**/node_modules/
**/dist/
**/dist-ssr/
**/.vite/
*.local

# --- Environment & secrets ---
.env
.env.local
.env.*.local
!.env.example
!.env*.example

# --- Logs ---
*.log
logs/

# --- OS ---
.DS_Store
Thumbs.db

# --- Editors (merged from former per-app Vite templates) ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

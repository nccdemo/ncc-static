# Driver app login URL after registration (standalone app or ncc-portal).
# VITE_DRIVER_LOGIN_URL=http://localhost:5174/
# VITE_DRIVER_LOGIN_URL=http://localhost:5177/driver/login

# Dev only: append ?token= to login URL when API returns access_token (set DRIVER_REGISTER_AUTO_APPROVE on backend).
# Driver app must set VITE_ACCEPT_TOKEN_FROM_URL=true to consume it (remove from URL after save).
# VITE_DRIVER_REGISTER_TOKEN_REDIRECT=false

# Copy to .env and fill in values. No spaces around =.
# python-dotenv: load_dotenv() runs at startup in app/main.py

DATABASE_URL=postgresql://user:password@localhost:5432/ncc_db

# Web app URL: quote links, emails tracking (/track/<token>), Stripe defaults. Default in code: http://localhost:5176
FRONTEND_URL=http://localhost:5176

# Stripe tour checkout browser return (success → /bnb-dashboard?success=true, cancel → /tours?canceled=true). Default: http://localhost:5177
# CLIENT_URL=http://localhost:5177
# STRIPE_CHECKOUT_RETURN_URL=http://localhost:5177
# Optional full overrides:
# STRIPE_TOUR_CHECKOUT_SUCCESS_URL=http://localhost:5177/bnb-dashboard?success=true
# STRIPE_TOUR_CHECKOUT_CANCEL_URL=http://localhost:5173/tours?canceled=true

# Optional: absolute URL of this API for assets in HTML emails (e.g. logo). Default: http://localhost:8000
# API_PUBLIC_URL=http://localhost:8000

# Nominatim user-agent (recommended: app name + contact URL or email)
# NOMINATIM_USER_AGENT=NCC-Backend/1.0 (https://your-domain.com)

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# Webhook signing secret: Dashboard endpoint OR `stripe listen` (must match forward URL)
# Forward to: http://localhost:8000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect: platform share on ride PaymentIntents when drivers.stripe_account_id is set (0.0–1.0; default 0.2). Trip commission_rate overrides when present.
# STRIPE_PLATFORM_FEE_RATE=0.2

# After payment_intent.succeeded: B&B referral commission as a fraction of the PI amount (0.0–1.0; default 0.1). Requires providers.stripe_account_id (Connect acct_…).
# STRIPE_BNB_COMMISSION_RATE=0.1

# Stripe Connect Express onboarding (POST /api/stripe/onboard). Defaults use STRIPE_CHECKOUT_RETURN_URL / CLIENT_URL / http://localhost:5177
# STRIPE_CONNECT_ONBOARDING_REFRESH_URL=http://localhost:5177/onboarding/refresh
# STRIPE_CONNECT_ONBOARDING_RETURN_URL=http://localhost:5177/onboarding/success

# Optional checkout URLs (defaults: /payment-success?booking_id=… or ?quote_id=… or ?tour_instance_id=…, cancel /payment-cancel)
# STRIPE_SUCCESS_URL=http://localhost:5176/payment-success?booking_id=1
# STRIPE_CANCEL_URL=http://localhost:5176/payment-cancel
# STRIPE_BOOKING_SUCCESS_URL=… STRIPE_BOOKING_CANCEL_URL=… STRIPE_QUOTE_SUCCESS_URL=… STRIPE_QUOTE_CANCEL_URL=…

# SMTP: either pair (SMTP_HOST + SMTP_USER + SMTP_PASSWORD) or legacy (SMTP_SERVER + EMAIL_USER + EMAIL_PASS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_USER=
EMAIL_PASS=
COMPANY_EMAIL=
SMTP_SERVER=smtps.aruba.it

# Driver self-registration (landing → POST /api/auth/driver/register):
# When true, new drivers are approved immediately and the register response may include access_token (dev/demo).
# Default: pending signup; admin approves via dashboard (Driver requests).
# DRIVER_REGISTER_AUTO_APPROVE=true

# B&B portal helpers (e.g. PUT /api/bnb/me, uploads): when 1/true (default), some routes accept a fixed user id without JWT. Use 0/false/no in production. Partner JWT routes are always ``/api/bnb/partner/*``.
# BNB_DASHBOARD_DEV_BYPASS=1
